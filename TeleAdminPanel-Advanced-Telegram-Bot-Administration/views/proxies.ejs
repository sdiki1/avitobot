<%- include('partials/header', { title: 'Прокси' }) %>

<section class="card">
  <h1>Прокси</h1>
  <p class="muted">Добавление/включение прокси для Avito-парсера.</p>

  <% if (success) { %>
    <div class="alert info"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <h2>Добавить прокси</h2>
  <form class="form-grid" action="<%= adminBase %>/proxies" method="post">
    <input name="name" placeholder="proxy-main-1" required />
    <input name="proxy_url" placeholder="http://user:pass@host:port" required />
    <input name="change_ip_url" placeholder="URL смены IP (опционально)" />
    <input type="date" name="expires_on" />
    <label>
      <input type="checkbox" name="is_active" checked /> Активен
    </label>
    <button type="submit">Добавить</button>
  </form>
</section>

<section class="card">
  <h2>Список прокси</h2>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Прокси</th>
          <th>Источник</th>
          <th>Срок</th>
          <th>Статус</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
      <% proxies.forEach((proxy) => { %>
        <%
          const isEnvProxy = String(proxy.name || '').startsWith('env-proxy-');
          const expiresOn = proxy.expires_on ? String(proxy.expires_on).slice(0, 10) : '';
        %>
        <tr>
          <td><%= proxy.id %></td>
          <td>
            <strong><%= proxy.name %></strong><br />
            <span class="muted"><%= proxy.proxy_url %></span><br />
            <span class="muted"><%= proxy.change_ip_url || '-' %></span><br />
            <span class="muted">Ошибок: <%= proxy.fail_count || 0 %></span>
          </td>
          <td><%= isEnvProxy ? '.env' : 'admin' %></td>
          <td>
            <% if (expiresOn) { %>
              <strong><%= expiresOn %></strong><br />
              <span class="muted">уведомление за 1 день</span>
            <% } else { %>
              <span class="muted">—</span>
            <% } %>
          </td>
          <td>
            <span class="badge <%= proxy.is_active ? 'active' : 'disabled' %>"><%= proxy.is_active ? 'active' : 'disabled' %></span>
            <% if (proxy.last_block_status) { %>
              <br />
              <span class="muted">последний блок: HTTP <%= proxy.last_block_status %></span>
            <% } %>
          </td>
          <td>
            <form class="form-grid two" action="<%= adminBase %>/proxies/<%= proxy.id %>/update" method="post">
              <input name="name" value="<%= proxy.name %>" required />
              <input name="proxy_url" value="<%= proxy.proxy_url %>" required />
              <input name="change_ip_url" value="<%= proxy.change_ip_url || '' %>" />
              <input type="date" name="expires_on" value="<%= expiresOn %>" />
              <label>
                <input
                  type="checkbox"
                  name="is_active"
                  class="js-proxy-active"
                  data-proxy-id="<%= proxy.id %>"
                  <%= proxy.is_active ? 'checked' : '' %>
                />
                Активен
              </label>
              <span class="muted js-proxy-active-state" data-proxy-id="<%= proxy.id %>"></span>
              <button type="submit">Сохранить</button>
            </form>
            <form action="<%= adminBase %>/proxies/<%= proxy.id %>/delete" method="post">
              <button class="danger" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<script>
  (function () {
    const adminBase = <%- JSON.stringify(adminBase) %>;
    const toggles = document.querySelectorAll('.js-proxy-active');

    toggles.forEach((toggle) => {
      toggle.addEventListener('change', async () => {
        const proxyId = toggle.dataset.proxyId;
        const info = document.querySelector(`.js-proxy-active-state[data-proxy-id="${proxyId}"]`);
        const nextState = toggle.checked;
        const previousState = !nextState;

        toggle.disabled = true;
        if (info) info.textContent = 'Сохраняем...';

        try {
          const response = await fetch(`${adminBase}/proxies/${proxyId}/active`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ is_active: nextState }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.ok) {
            throw new Error(payload.error || 'Не удалось обновить прокси');
          }
          if (info) info.textContent = 'Сохранено';
        } catch (error) {
          toggle.checked = previousState;
          if (info) info.textContent = `Ошибка: ${error.message}`;
        } finally {
          toggle.disabled = false;
        }
      });
    });
  })();
</script>

<%- include('partials/footer') %>
