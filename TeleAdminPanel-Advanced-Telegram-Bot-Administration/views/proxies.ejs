<%- include('partials/header', { title: 'Прокси' }) %>

<section class="card">
  <h1>Прокси</h1>
  <p class="muted">Добавление/включение прокси для Avito-парсера.</p>

  <% if (success) { %>
    <div class="alert info"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <h2>Добавить прокси</h2>
  <form class="form-grid" action="<%= adminBase %>/proxies" method="post">
    <input name="name" placeholder="proxy-main-1" required />
    <input name="proxy_url" placeholder="http://user:pass@host:port" required />
    <input name="change_ip_url" placeholder="URL смены IP (опционально)" />
    <label>
      <input type="checkbox" name="is_active" checked /> Активен
    </label>
    <button type="submit">Добавить</button>
  </form>
</section>

<section class="card">
  <h2>Список прокси</h2>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Прокси</th>
          <th>Источник</th>
          <th>Статус</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
      <% proxies.forEach((proxy) => { %>
        <%
          const isEnvProxy = String(proxy.name || '').startsWith('env-proxy-');
          const cooldownUntilMs = proxy.cooldown_until ? new Date(proxy.cooldown_until).getTime() : 0;
          const isCooling = Boolean(proxy.is_active && cooldownUntilMs && cooldownUntilMs > Date.now());
          const runtimeClass = !proxy.is_active ? 'disabled' : (isCooling ? 'pending' : 'active');
          const runtimeLabel = !proxy.is_active ? 'disabled' : (isCooling ? 'cooldown' : 'working');
        %>
        <tr>
          <td><%= proxy.id %></td>
          <td>
            <strong><%= proxy.name %></strong><br />
            <span class="muted"><%= proxy.proxy_url %></span><br />
            <span class="muted"><%= proxy.change_ip_url || '-' %></span><br />
            <span class="muted">Ошибок: <%= proxy.fail_count || 0 %></span>
          </td>
          <td><%= isEnvProxy ? '.env' : 'admin' %></td>
          <td>
            <span class="badge <%= proxy.is_active ? 'active' : 'disabled' %>"><%= proxy.is_active ? 'active' : 'disabled' %></span>
            <span class="badge <%= runtimeClass %>"><%= runtimeLabel %></span><br />
            <% if (proxy.cooldown_until) { %>
              <span class="muted">cooldown до: <%= proxy.cooldown_until %></span><br />
            <% } %>
            <% if (proxy.last_block_status) { %>
              <span class="muted">последний блок: HTTP <%= proxy.last_block_status %></span>
            <% } %>
          </td>
          <td>
            <form class="form-grid two" action="<%= adminBase %>/proxies/<%= proxy.id %>/update" method="post">
              <input name="name" value="<%= proxy.name %>" required />
              <input name="proxy_url" value="<%= proxy.proxy_url %>" required />
              <input name="change_ip_url" value="<%= proxy.change_ip_url || '' %>" />
              <label>
                <input type="checkbox" name="is_active" <%= proxy.is_active ? 'checked' : '' %> /> Активен
              </label>
              <button type="submit">Сохранить</button>
            </form>
            <form action="<%= adminBase %>/proxies/<%= proxy.id %>/delete" method="post">
              <button class="danger" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
