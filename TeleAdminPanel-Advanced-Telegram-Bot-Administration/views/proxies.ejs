<%- include('partials/header', { title: 'Прокси' }) %>

<section class="card">
  <h1>Прокси</h1>
  <p class="muted">Добавление/включение прокси для Avito-парсера.</p>

  <% if (success) { %>
    <div class="alert info"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
  <% if (stats && !stats.proxy_capacity_ok) { %>
    <div class="alert error">
      Недостаточно прокси: активных мониторингов <%= stats.active_monitorings %>,
      рабочих прокси <%= stats.active_proxies %>, нужно минимум <%= stats.required_proxies %>.
      Добавьте еще <%= stats.missing_proxies %> прокси.
    </div>
  <% } %>
  <p class="muted">
    Норма: 2 рабочих прокси на 1 активный мониторинг.
    Текущий запас: <%= stats?.proxy_capacity_monitorings ?? 0 %> мониторингов.
  </p>

  <h2>Добавить прокси</h2>
  <form class="form-grid" action="<%= adminBase %>/proxies/create" method="get">
    <label class="field">
      <span>Название (необязательно)</span>
      <input name="name" placeholder="Сгенерируется автоматически" />
    </label>
    <label class="field">
      <span>Прокси</span>
      <input name="proxy_url" placeholder="socks5://user:pass@host:port" />
    </label>
    <label class="field">
      <span>Альтернативная ссылка</span>
      <input name="alternative_proxy_url" placeholder="ip:port:login:pass" />
    </label>
    <label class="field">
      <span>URL смены IP</span>
      <input name="change_ip_url" placeholder="Опционально" />
    </label>
    <label class="field">
      <span>Срок, дней</span>
      <input type="number" name="expires_days" min="1" value="30" placeholder="30" />
    </label>
    <label class="field">
      <span>Дата окончания</span>
      <input type="date" name="expires_on" />
    </label>
    <label>
      <input type="checkbox" name="is_active" checked /> Активен
    </label>
    <button type="submit">Добавить</button>
  </form>
</section>

<section class="card">
  <h2>Список прокси</h2>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Прокси</th>
          <th>Источник</th>
          <th>Срок</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
      <% proxies.forEach((proxy) => { %>
        <%
          const isEnvProxy = String(proxy.name || '').startsWith('env-proxy-');
          const expiresOn = proxy.expires_on ? String(proxy.expires_on).slice(0, 10) : '';
        %>
        <tr>
          <td><%= proxy.id %></td>
          <td>
            <strong><%= proxy.name %></strong><br />
            <span class="muted"><%= proxy.proxy_url %></span><br />
            <span class="muted"><%= proxy.change_ip_url || '-' %></span>
          </td>
          <td><%= isEnvProxy ? '.env' : 'admin' %></td>
          <td>
            <% if (expiresOn) { %>
              <strong><%= expiresOn %></strong><br />
              <span class="muted">последний день действия; удаление на следующий день</span>
            <% } else { %>
              <span class="muted">—</span>
            <% } %>
          </td>
          <td>
            <form class="form-grid two" action="<%= adminBase %>/proxies/<%= proxy.id %>/update" method="get">
              <label class="field">
                <span>Название</span>
                <input name="name" value="<%= proxy.name %>" required />
              </label>
              <label class="field">
                <span>Прокси</span>
                <input name="proxy_url" value="<%= proxy.proxy_url %>" required />
              </label>
              <label class="field">
                <span>Альтернативная ссылка</span>
                <input name="alternative_proxy_url" placeholder="ip:port:login:pass" />
              </label>
              <label class="field">
                <span>URL смены IP</span>
                <input name="change_ip_url" value="<%= proxy.change_ip_url || '' %>" />
              </label>
              <label class="field">
                <span>Продлить на дней</span>
                <input type="number" name="expires_days" min="1" placeholder="30" />
              </label>
              <label class="field">
                <span>Дата окончания</span>
                <input type="date" name="expires_on" value="<%= expiresOn %>" />
              </label>
              <label>
                <input
                  type="checkbox"
                  name="is_active"
                  class="js-proxy-active"
                  data-proxy-id="<%= proxy.id %>"
                  <%= proxy.is_active ? 'checked' : '' %>
                />
                Активен
              </label>
              <span class="muted js-proxy-active-state" data-proxy-id="<%= proxy.id %>"></span>
              <button type="submit">Сохранить</button>
            </form>
            <form action="<%= adminBase %>/proxies/<%= proxy.id %>/delete" method="get">
              <button class="danger" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<script>
  (function () {
    const adminBase = <%- JSON.stringify(adminBase) %>;
    const toggles = document.querySelectorAll('.js-proxy-active');

    toggles.forEach((toggle) => {
      toggle.addEventListener('change', async () => {
        const proxyId = toggle.dataset.proxyId;
        const info = document.querySelector(`.js-proxy-active-state[data-proxy-id="${proxyId}"]`);
        const nextState = toggle.checked;
        const previousState = !nextState;

        toggle.disabled = true;
        if (info) info.textContent = 'Сохраняем...';

        try {
          const params = new URLSearchParams({ is_active: String(nextState) });
          const response = await fetch(`${adminBase}/proxies/${proxyId}/active?${params.toString()}`);
          const payload = await response.json();
          if (!response.ok || !payload.ok) {
            throw new Error(payload.error || 'Не удалось обновить прокси');
          }
          if (info) info.textContent = 'Сохранено';
        } catch (error) {
          toggle.checked = previousState;
          if (info) info.textContent = `Ошибка: ${error.message}`;
        } finally {
          toggle.disabled = false;
        }
      });
    });
  })();
</script>

<%- include('partials/footer') %>
