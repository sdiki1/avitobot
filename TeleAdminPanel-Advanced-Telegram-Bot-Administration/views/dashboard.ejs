<%- include('partials/header', { title: 'Admin Dashboard' }) %>

<section class="card">
  <h1>Avito Bot Admin</h1>
  <p class="muted">Управление продажей Avito-парсинга: пользователи, тарифы, прокси, подписки, платежи.</p>

  <% if (success) { %>
    <div class="alert info"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
</section>

<section class="grid metrics">
  <article class="metric">
    <span>Пользователи</span>
    <strong><%= stats.users_count %></strong>
  </article>
  <article class="metric">
    <span>Активные мониторинги</span>
    <strong><%= stats.active_monitorings %></strong>
  </article>
  <article class="metric">
    <span>Активные подписки</span>
    <strong><%= stats.active_subscriptions %></strong>
  </article>
  <article class="metric">
    <span>Выручка</span>
    <strong><%= stats.payments_total_rub %> ₽</strong>
  </article>
  <article class="metric">
    <span>Активные боты</span>
    <strong><%= stats.active_bots %></strong>
  </article>
</section>

<section class="card">
  <h2>Быстрая активация подписки</h2>
  <form class="form-grid" action="<%= adminBase %>/subscriptions/activate" method="post">
    <input name="telegram_id" type="number" placeholder="Telegram ID пользователя" required />
    <select name="plan_id" required>
      <option value="">Выберите тариф</option>
      <% plans.forEach((plan) => { %>
        <option value="<%= plan.id %>"><%= plan.name %> · <%= plan.price_rub %> ₽</option>
      <% }) %>
    </select>
    <button type="submit">Активировать</button>
  </form>
</section>

<section class="card">
  <h2>Пробный период</h2>
  <form class="form-grid two" action="<%= adminBase %>/trial-settings/update" method="post">
    <input
      name="trial_days"
      type="number"
      min="0"
      value="<%= trialSettings?.trial_days ?? 0 %>"
      placeholder="Дней пробного периода"
      required
    />
    <button type="submit">Сохранить</button>
  </form>
  <p class="muted">0 дней = пробный период выключен. Пробный период выдается только при первой покупке.</p>
</section>

<section class="card">
  <h2>Контент MiniApp</h2>
  <p class="muted">Заполняйте блоки miniapp: Информация, Подписки и Профиль.</p>
  <form class="stack" action="<%= adminBase %>/miniapp-content/update" method="post">
    <div class="content-editor">
      <h3>Блок «Информация»</h3>
      <div class="form-grid two">
        <input name="support_title" value="<%= miniappContent?.support_title || '' %>" placeholder="Поддержка: заголовок" required />
        <input name="support_url" value="<%= miniappContent?.support_url || '' %>" placeholder="Поддержка: URL" required />

        <input name="faq_title" value="<%= miniappContent?.faq_title || '' %>" placeholder="FAQ: заголовок" required />
        <input name="faq_url" value="<%= miniappContent?.faq_url || '' %>" placeholder="FAQ: URL" required />

        <input name="news_title" value="<%= miniappContent?.news_title || '' %>" placeholder="Новости: заголовок" required />
        <input name="news_url" value="<%= miniappContent?.news_url || '' %>" placeholder="Новости: URL" required />

        <input name="terms_title" value="<%= miniappContent?.terms_title || '' %>" placeholder="Соглашение: заголовок" required />
        <input name="terms_url" value="<%= miniappContent?.terms_url || '' %>" placeholder="Соглашение: URL" required />

        <input name="privacy_title" value="<%= miniappContent?.privacy_title || '' %>" placeholder="Privacy: заголовок" required />
        <input name="privacy_url" value="<%= miniappContent?.privacy_url || '' %>" placeholder="Privacy: URL" required />
      </div>
    </div>

    <div class="content-editor">
      <h3>Блок «Подписки»</h3>
      <div class="form-grid two">
        <input
          name="subscriptions_title"
          value="<%= miniappContent?.subscriptions_title || '' %>"
          placeholder="Заголовок блока подписок"
          required
        />
        <input
          name="subscriptions_hint"
          value="<%= miniappContent?.subscriptions_hint || '' %>"
          placeholder="Подпись под заголовком"
          required
        />
      </div>
    </div>

    <div class="content-editor">
      <h3>Блок «Профиль»</h3>
      <div class="form-grid two">
        <input
          name="profile_title"
          value="<%= miniappContent?.profile_title || '' %>"
          placeholder="Заголовок блока профиля"
          required
        />
      </div>
    </div>

    <button type="submit">Сохранить контент MiniApp</button>
  </form>
</section>

<section class="card">
  <h2>Подключенные боты</h2>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Имя</th>
          <th>Username</th>
          <th>Статус</th>
        </tr>
      </thead>
      <tbody>
      <% bots.forEach((bot) => { %>
        <tr>
          <td><%= bot.id %></td>
          <td><%= bot.name %></td>
          <td><%= bot.bot_username ? `@${bot.bot_username}` : '—' %></td>
          <td><span class="badge <%= bot.is_active ? 'active' : 'disabled' %>"><%= bot.is_active ? 'active' : 'disabled' %></span></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="card">
  <h2>Активные прокси</h2>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Название</th>
          <th>Proxy URL</th>
          <th>Статус</th>
        </tr>
      </thead>
      <tbody>
      <% proxies.forEach((proxy) => { %>
        <tr>
          <td><%= proxy.id %></td>
          <td><%= proxy.name %></td>
          <td><%= proxy.proxy_url %></td>
          <td><span class="badge <%= proxy.is_active ? 'active' : 'disabled' %>"><%= proxy.is_active ? 'active' : 'disabled' %></span></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
