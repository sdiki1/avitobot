<%- include('partials/header', { title: 'Мониторинги' }) %>

<section class="card">
  <h1>Мониторинги Avito</h1>
  <% if (success) { %>
    <div class="alert info"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>User ID</th>
          <th>Бот</th>
          <th>Название / URL</th>
          <th>Последняя проверка</th>
          <th>Статус</th>
          <th>Управление</th>
        </tr>
      </thead>
      <tbody>
      <% monitorings.forEach((m) => { %>
        <tr>
          <td><strong><%= m.id %></strong></td>
          <td><%= m.user_id %></td>
          <td>
            <% if (m.bot_id) { %>
              <div class="user-meta">
                <strong>#<%= m.bot_id %> <%= m.bot_name || 'Без имени' %></strong>
                <% if (m.bot_link) { %>
                  <a href="<%= m.bot_link %>" target="_blank" rel="noreferrer"><%= m.bot_link %></a>
                <% } %>
              </div>
            <% } else { %>
              —
            <% } %>
          </td>
          <td>
            <div class="user-meta">
              <strong><%= m.title || `Мониторинг #${m.id}` %></strong>
              <span class="monitoring-url"><%= m.url %></span>
            </div>
          </td>
          <td class="muted"><%= m.last_checked_at || '—' %></td>
          <td>
            <span class="badge <%= m.is_active ? 'active' : 'disabled' %>">
              <%= m.is_active ? 'active' : 'disabled' %>
            </span>
            <% if (!m.link_configured) { %>
              <span class="badge pending">no-link</span>
            <% } %>
          </td>
          <td>
            <form class="stack" action="<%= adminBase %>/monitorings/<%= m.id %>/update" method="post">
              <input name="title" value="<%= m.title || '' %>" placeholder="Название" />
              <input name="url" value="<%= m.url || '' %>" placeholder="https://www.avito.ru/..." />
              <label>
                <input name="is_active" type="checkbox" <%= m.is_active ? 'checked' : '' %> />
                Активен
              </label>
              <label>
                <input name="include_photo" type="checkbox" <%= m.include_photo ? 'checked' : '' %> />
                Фотография
              </label>
              <label>
                <input name="include_description" type="checkbox" <%= m.include_description ? 'checked' : '' %> />
                Описание
              </label>
              <label>
                <input name="include_seller_info" type="checkbox" <%= m.include_seller_info ? 'checked' : '' %> />
                Инфо продавца
              </label>
              <label>
                <input name="notify_price_drop" type="checkbox" <%= m.notify_price_drop ? 'checked' : '' %> />
                Снижение цены
              </label>
              <button type="submit">Сохранить</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
