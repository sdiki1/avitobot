<%- include('partials/header', { title: 'Тарифы' }) %>

<section class="card">
  <h1>Тарифы Mini App</h1>
  <p class="muted">В этом разделе доступны только типы из miniapp: «Стандартная» и «Скоростная».</p>

  <% if (success) { %>
    <div class="alert info"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
  <% if (hiddenPlansCount > 0) { %>
    <p class="muted">Скрыто нестандартных тарифов: <strong><%= hiddenPlansCount %></strong></p>
  <% } %>
</section>

<section class="card">
  <h2>Редактирование тарифов</h2>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Тип</th>
          <th>Параметры</th>
          <th>Управление</th>
        </tr>
      </thead>
      <tbody>
      <% plans.forEach((plan) => { %>
        <tr>
          <td>
            <strong><%= plan.name %></strong><br />
            <span class="muted"><%= plan.id ? `ID ${plan.id}` : 'Будет создан при сохранении' %></span>
          </td>
          <td>
            <span class="muted"><%= plan.links_limit %> ссылок · <%= plan.duration_days %> дней · <%= plan.price_rub %> ₽</span><br />
            <span class="badge <%= plan.is_active ? 'active' : 'disabled' %>"><%= plan.is_active ? 'active' : 'disabled' %></span>
          </td>
          <td>
            <form class="form-grid two" action="<%= adminBase %>/plans/miniapp/<%= plan.key %>/save" method="post">
              <input type="hidden" name="plan_id" value="<%= plan.id || '' %>" />
              <input name="description" value="<%= plan.description || '' %>" placeholder="Описание" />
              <input name="links_limit" type="number" value="<%= plan.links_limit %>" required />
              <input name="duration_days" type="number" value="<%= plan.duration_days %>" required />
              <input name="price_rub" type="number" value="<%= plan.price_rub %>" required />
              <label>
                <input type="checkbox" name="is_active" <%= plan.is_active ? 'checked' : '' %> /> Активен
              </label>
              <div class="actions">
                <button type="submit">Сохранить</button>
              </div>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
